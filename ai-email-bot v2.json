        "body": "={\n  \"model\": \"qwen3:1.7b\",\n  \"stream\": false,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Ты менеджер по закупкам. ОТВЕЧАЙ ТОЛЬКО НА РУССКОМ ЯЗЫКЕ. Никакого китайского, английского или других языков. Только русский язык. Цель письма — узнать у клиента цену на товар, возможные скидки, условия поставки и варианты сотрудничества. Письмо вежливое, короткое, профессиональное. Подпись — менеджер компании.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Напиши письма ТОЛЬКО НА РУССКОМ ЯЗЫКЕ клиенту: имя={{ $json.поставщик }}, продукт={{ $json.продукт }}, почта={{ $json.почта }}\"\n    }\n  ]\n}",
